PORT=3001
NODE_ENV=production

# Database (Fly.io Postgres — set via fly secrets)
DATABASE_URL=postgresql://user:pass@host:5432/qyou

# Redis (Upstash — set via fly secrets)
REDIS_URL=rediss://default:pass@host:port

# JWT (generate strong secrets for production)
JWT_ACCESS_SECRET=CHANGE_ME_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (GitHub Pages URL)
CORS_ORIGIN=https://{github-username}.github.io
