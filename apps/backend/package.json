{
  "name": "@qyou/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down",
    "check-env": "bash scripts/check-env.sh"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^7.0.0",
    "otplib": "^13.4.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
